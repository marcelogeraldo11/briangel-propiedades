---
import Input from '../shared/Input.astro';
import Textarea from '../shared/Textarea.astro';
import Select from '../shared/Select.astro';
import Icon from '../shared/Icon.astro';

const interestTypes = [
  { value: 'venta', label: 'Venta' },
  { value: 'arriendo', label: 'Arriendo' }
];

const propertyTypes = [
  { value: 'apartamento', label: 'Apartamento' },
  { value: 'casa', label: 'Casa' },
  { value: 'local', label: 'Local' },
  { value: 'oficina', label: 'Oficina' }
];
---

<div class="bg-white dark:bg-slate-900 p-8 md:p-12 rounded shadow-sm border border-slate-200 dark:border-slate-800">
  <form action="#" class="space-y-8" method="POST">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <Input label="Nombre completo" name="name" placeholder="Tu nombre" required />
      <Input label="Correo" name="email" type="email" placeholder="tu@correo.com" required />
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <Select label="Interés" name="interest" options={interestTypes} />
      <Select label="Tipo de propiedad" name="propertyType" options={propertyTypes} />
    </div>
    
    <Textarea 
      label="Mensaje" 
      name="message" 
      placeholder="Zona, presupuesto, número de habitaciones (si aplica) y cualquier detalle importante..." 
      rows={6} 
      required 
    />
    
    <button 
      type="submit" 
      class="w-full md:w-auto bg-primary text-white px-10 py-4 rounded font-bold uppercase tracking-widest hover:bg-primary/90 transition-all flex items-center justify-center gap-3 group"
    >
      Enviar
      <Icon name="send" size={18} class="transition-transform group-hover:translate-x-1" />
    </button>
  </form>
</div>

---
import Container from "../shared/Container.astro";
import ProjectCard from "./ProjectCard.astro";
import Icon from "../shared/Icon.astro";
import { properties } from "../../data/properties";

const featured = properties.slice(0, 4);
---

<section class="py-24 md:py-32">
  <Container>
    <div
      class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6"
    >
      <div class="max-w-xl">
        <span
          class="text-primary font-bold uppercase tracking-[0.3em] text-xs mb-4 block"
          >Destacadas</span
        >
        <h2
          class="text-4xl md:text-5xl font-black tracking-tighter uppercase leading-none"
        >
          Propiedades
        </h2>
      </div>
      <a
        href="/projects"
        class="group flex items-center gap-2 text-sm font-bold uppercase tracking-widest border-b-2 border-primary pb-1"
      >
        Ver todas
        <Icon
          name="arrow-right"
          size={16}
          class="group-hover:translate-x-1 transition-transform"
        />
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12">
      {
        featured.map((property, index) => (
          <ProjectCard
            slug={property.slug}
            title={property.title}
            operation={property.operation}
            price={property.price}
            location={property.location}
            image={property.images[0]}
            alt={property.title}
            index={index}
          />
        ))
      }
    </div>
  </Container>
</section>

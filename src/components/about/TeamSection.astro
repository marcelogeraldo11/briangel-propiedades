---
import Container from "../shared/Container.astro";
import Icon from "../shared/Icon.astro";
import TeamMember from "./TeamMember.astro";
import team1Image from "../../assets/img/about-page-img-01.jpg";
import team2Image from "../../assets/img/about-page-img-02.jpg";
import team3Image from "../../assets/img/about-page-img-03.jpg";
import team4Image from "../../assets/img/about-page-img-04.jpg";

const team = [
  {
    name: "Olga Castillo",
    role: "Asesor Comercial",
    image: team1Image,
    alt: "Professional portrait of male principal architect with glasses and suit",
  },
  {
    name: "Señora Briangel",
    role: "Asesora Inmobiliaria",
    image: team2Image,
    alt: "Professional portrait of female lead interior designer with modern attire",
  },
];
---

<section class="py-24 bg-white dark:bg-slate-900/30">
  <Container>
    <div
      class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6"
    >
      <div class="max-w-xl">
        <div class="flex items-center gap-4 mb-4">
          <div class="h-[1px] w-12 bg-primary"></div>
          <h2 class="text-sm font-bold uppercase tracking-[0.3em] text-primary">
            Equipo
          </h2>
        </div>
        <h3 class="text-4xl font-black">Personas que te acompañan</h3>
      </div>
      <a
        href="/contact"
        class="group flex items-center gap-2 text-primary font-bold text-sm hover:gap-3 transition-all"
      >
        Habla con nosotros
        <Icon
          name="arrow-right"
          size={20}
          class="transition-transform group-hover:translate-x-1"
        />
      </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {
        team.map((member) => (
          <TeamMember
            name={member.name}
            role={member.role}
            image={member.image}
            alt={member.alt}
          />
        ))
      }
    </div>
  </Container>
</section>

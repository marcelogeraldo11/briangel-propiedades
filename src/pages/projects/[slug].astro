---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/home/Navbar.astro";
import Footer from "../../components/shared/Footer.astro";
import Container from "../../components/shared/Container.astro";
import Icon from "../../components/shared/Icon.astro";
import Button from "../../components/shared/Button.astro";
import { Image } from "astro:assets";
import { properties } from "../../data/properties";

export function getStaticPaths() {
  return properties.map((property) => ({
    params: { slug: property.slug },
  }));
}

const { slug } = Astro.params;
const property = properties.find((p) => p.slug === slug);
const similar = properties.filter((p) => p.slug !== slug).slice(0, 3);

const title = property
  ? `${property.title} | ${property.operation}`
  : "Propiedad no encontrada";
const description = property
  ? `${property.type} en ${property.location}. ${property.operation} • ${property.price}.`
  : "No encontramos la propiedad solicitada.";
---

<Layout title={title} description={description}>
  <Navbar />
  <main class="flex-1">
    <section class="pt-24">
      <Container size="xl">
        <div class="flex items-center justify-between gap-6">
          <nav
            class="flex flex-wrap items-center gap-x-2 gap-y-1 text-xs font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400"
          >
            <a href="/" class="hover:text-primary transition-colors">Inicio</a>
            <span class="opacity-60">/</span>
            <a href="/projects" class="hover:text-primary transition-colors"
              >Propiedades</a
            >
            <span class="opacity-60">/</span>
            <span class="text-slate-900 dark:text-slate-100">
              {property ? property.type : "Detalle"}
            </span>
          </nav>

          <a
            href="/projects"
            class="hidden sm:inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-primary"
          >
            <Icon name="arrow-right" size={16} class="rotate-180" />
            Volver
          </a>
        </div>
      </Container>
    </section>

    {
      property ? (
        <section class="pt-10 pb-16">
          <Container size="xl">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-14 items-start">
              <div class="lg:col-span-8">
                <div class="relative overflow-hidden rounded-2xl bg-slate-200 dark:bg-slate-900 border border-slate-200 dark:border-slate-800">
                  <div class="absolute inset-0 bg-[radial-gradient(800px_300px_at_0%_0%,color-mix(in_srgb,var(--color-primary)_22%,transparent),transparent_70%)]" />
                  <div class="absolute inset-0 bg-[radial-gradient(900px_420px_at_100%_10%,rgba(255,255,255,0.20),transparent_60%)] dark:bg-[radial-gradient(900px_420px_at_100%_10%,rgba(255,255,255,0.08),transparent_60%)]" />

                  <div class="relative">
                    <div class="absolute top-5 left-5 z-20 flex flex-wrap items-center gap-2">
                      <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest bg-white/90 text-slate-900">
                        {property.operation}
                      </span>
                      <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest bg-white/90 text-slate-900">
                        {property.type}
                      </span>
                    </div>

                    <div class="absolute top-5 right-5 z-20">
                      <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest bg-white/90 text-slate-900">
                        {property.price}
                      </span>
                    </div>

                    <div class="aspect-[16/10]">
                      <Image
                        src={property.images[0]}
                        alt={property.title}
                        class="w-full h-full object-cover"
                        loading="eager"
                        fetchpriority="high"
                        widths={[640, 960, 1280, property.images[0].width]}
                        sizes="(max-width: 1024px) 100vw, 66vw"
                        quality={80}
                        format="webp"
                      />
                    </div>
                  </div>
                </div>

                <div class="mt-10">
                  <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
                    <div class="max-w-2xl">
                      <h1 class="text-4xl md:text-6xl font-black tracking-tight leading-[0.95]">
                        {property.title}
                      </h1>
                      <p class="mt-4 text-slate-600 dark:text-slate-300 text-base md:text-lg font-light leading-relaxed">
                        {property.description}
                      </p>
                      <div class="mt-6 flex flex-wrap items-center gap-3 text-sm">
                        <span class="inline-flex items-center gap-2 px-3 py-2 rounded-lg bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800">
                          <Icon name="map-pin" size={18} class="text-primary" />
                          <span class="text-slate-700 dark:text-slate-300">
                            {property.location}
                          </span>
                        </span>
                        {typeof property.stratum === "number" ? (
                          <span class="inline-flex items-center gap-2 px-3 py-2 rounded-lg bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800">
                            <Icon
                              name="shield"
                              size={18}
                              class="text-primary"
                            />
                            <span class="text-slate-700 dark:text-slate-300">
                              Estrato {property.stratum}
                            </span>
                          </span>
                        ) : null}
                      </div>
                    </div>

                    <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3">
                      <Button
                        href="/contact"
                        variant="primary"
                        size="md"
                        class="w-full sm:w-auto"
                      >
                        Quiero más info
                      </Button>
                      <Button
                        href="/projects"
                        variant="outline"
                        size="md"
                        class="w-full sm:w-auto"
                      >
                        Seguir buscando
                      </Button>
                    </div>
                  </div>

                  <div class="mt-10 grid grid-cols-2 md:grid-cols-4 gap-4">
                    {typeof property.bedrooms === "number" ? (
                      <div class="rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-5">
                        <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400">
                          Habitaciones
                        </p>
                        <p class="mt-2 text-2xl font-black tracking-tight">
                          {property.bedrooms}
                        </p>
                      </div>
                    ) : null}
                    {typeof property.bathrooms === "number" ? (
                      <div class="rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-5">
                        <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400">
                          Baños
                        </p>
                        <p class="mt-2 text-2xl font-black tracking-tight">
                          {property.bathrooms}
                        </p>
                      </div>
                    ) : null}
                    {typeof property.areaM2 === "number" ? (
                      <div class="rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-5">
                        <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400">
                          Área
                        </p>
                        <p class="mt-2 text-2xl font-black tracking-tight">
                          {property.areaM2} m²
                        </p>
                      </div>
                    ) : null}
                    {typeof property.parking === "number" ? (
                      <div class="rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-5">
                        <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400">
                          Parqueaderos
                        </p>
                        <p class="mt-2 text-2xl font-black tracking-tight">
                          {property.parking}
                        </p>
                      </div>
                    ) : null}
                  </div>

                  <div class="mt-12 grid grid-cols-1 md:grid-cols-12 gap-8">
                    <div class="md:col-span-7">
                      <h2 class="text-sm font-bold uppercase tracking-[0.25em] text-primary">
                        Detalles
                      </h2>
                      <div class="mt-5 rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-7">
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                          {property.features.map((feature) => (
                            <div class="flex items-start gap-3">
                              <Icon
                                name="check"
                                size={18}
                                class="text-primary mt-0.5"
                              />
                              <span class="text-slate-700 dark:text-slate-300 text-sm leading-relaxed">
                                {feature}
                              </span>
                            </div>
                          ))}
                        </div>
                      </div>
                    </div>

                    <div class="md:col-span-5">
                      <h2 class="text-sm font-bold uppercase tracking-[0.25em] text-primary">
                        Galería
                      </h2>
                      <div class="mt-5">
                        <div class="grid grid-cols-3 gap-1.5">
                          {property.images.map((img, index) => (
                            <button
                              type="button"
                              data-gallery-item
                              data-gallery-index={index}
                              data-lightbox-src={img.src}
                              data-lightbox-alt={`${property.title} - imagen ${index + 1}`}
                              class:list={[
                                "group/t relative overflow-hidden rounded-lg bg-slate-200 dark:bg-slate-800 cursor-zoom-in",
                                index === 0 ? "col-span-3 aspect-[16/9]" : "col-span-1 aspect-square",
                                index > 6 ? "hidden" : "",
                              ]}
                            >
                              <Image
                                src={img}
                                alt={`${property.title} - imagen ${index + 1}`}
                                class="w-full h-full object-cover transition-all duration-500 group-hover/t:scale-105 group-hover/t:brightness-75"
                                loading={index === 0 ? "eager" : "lazy"}
                                decoding="async"
                                widths={[360, 540, 720, img.width]}
                                sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 25vw"
                                quality={75}
                                format="webp"
                              />
                              {index === 6 && property.images.length > 7 ? (
                                <div class="absolute inset-0 bg-slate-900/60 flex items-center justify-center pointer-events-none">
                                  <div class="text-center text-white">
                                    <p class="text-2xl font-black">+{property.images.length - 7}</p>
                                    <p class="text-[10px] font-bold uppercase tracking-widest mt-1 opacity-80">más fotos</p>
                                  </div>
                                </div>
                              ) : (
                                <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover/t:opacity-100 transition-opacity duration-300 pointer-events-none">
                                  <span class="rounded-full bg-white/90 backdrop-blur-sm p-2.5 shadow-lg">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/><path d="M11 8v6M8 11h6"/></svg>
                                  </span>
                                </div>
                              )}
                            </button>
                          ))}
                        </div>
                        {property.images.length > 7 ? (
                          <button
                            type="button"
                            data-gallery-open
                            class="mt-3 w-full rounded-lg border border-slate-200 dark:border-slate-700 py-2.5 text-xs font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400 hover:text-primary hover:border-primary/40 transition-colors"
                          >
                            Ver las {property.images.length} fotos
                          </button>
                        ) : null}
                      </div>

                      <div
                        class="fixed inset-0 z-[80]"
                        data-lightbox
                        aria-hidden="true"
                        style="display:none;opacity:0;transition:opacity 0.25s ease;"
                      >
                        <div
                          class="absolute inset-0 bg-black/95 backdrop-blur-md"
                          data-lightbox-backdrop
                        ></div>
                        <div class="relative w-full h-full flex flex-col">
                          <!-- Barra superior -->
                          <div class="relative z-10 flex items-center justify-between px-4 py-4 sm:px-6 shrink-0">
                            <div class="text-xs font-bold uppercase tracking-widest text-white/60 bg-white/10 rounded-full px-3 py-1.5 border border-white/10">
                              <span data-lightbox-count></span>
                            </div>
                            <button
                              type="button"
                              class="rounded-full bg-white/10 hover:bg-white/20 text-white p-2.5 transition-colors backdrop-blur-sm border border-white/10"
                              aria-label="Cerrar"
                              data-lightbox-close
                            >
                              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                            </button>
                          </div>
                          <!-- Área imagen principal -->
                          <div class="relative flex-1 flex items-center justify-center px-16 sm:px-20 min-h-0">
                            <button
                              type="button"
                              class="absolute left-3 sm:left-4 z-20 rounded-full bg-white/10 hover:bg-white/20 text-white p-3 transition-colors backdrop-blur-sm border border-white/10"
                              aria-label="Anterior"
                              data-lightbox-prev
                            >
                              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
                            </button>
                            <div class="relative w-full h-full flex items-center justify-center">
                              <div data-lightbox-loader class="absolute inset-0 flex items-center justify-center opacity-0 pointer-events-none" style="transition:opacity 0.2s ease;">
                                <div class="w-8 h-8 rounded-full border-2 border-white/20 border-t-white animate-spin"></div>
                              </div>
                              <img
                                data-lightbox-img
                                alt=""
                                class="max-w-full max-h-full object-contain rounded-xl shadow-2xl"
                                style="transition:opacity 0.2s ease;"
                                loading="eager"
                                decoding="async"
                              />
                            </div>
                            <button
                              type="button"
                              class="absolute right-3 sm:right-4 z-20 rounded-full bg-white/10 hover:bg-white/20 text-white p-3 transition-colors backdrop-blur-sm border border-white/10"
                              aria-label="Siguiente"
                              data-lightbox-next
                            >
                              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                            </button>
                          </div>
                          <!-- Tira de miniaturas -->
                          <div class="relative z-10 h-24 shrink-0 flex items-center border-t border-white/10">
                            <div
                              class="flex gap-2 overflow-x-auto w-full px-4 py-2"
                              data-lightbox-thumbs
                              style="scrollbar-width:none;-ms-overflow-style:none;"
                            ></div>
                          </div>
                        </div>
                      </div>

                      <div class="mt-8 rounded-2xl border border-primary/20 bg-primary/5 dark:bg-primary/10 p-7">
                        <p class="text-xs font-bold uppercase tracking-widest text-primary">
                          ¿Te interesa esta propiedad?
                        </p>
                        <p class="mt-3 text-sm text-slate-700 dark:text-slate-200 leading-relaxed">
                          Te ayudamos a agendar visita y resolver dudas de
                          documentación y negociación.
                        </p>
                        <div class="mt-6">
                          <Button
                            href={`/contact?propiedad=${property.slug}`}
                            variant="primary"
                            size="md"
                          >
                            Agendar visita
                          </Button>
                        </div>
                      </div>
                    </div>
                  </div>

                  {similar.length ? (
                    <div class="mt-16">
                      <div class="flex items-end justify-between gap-6">
                        <div>
                          <h2 class="text-sm font-bold uppercase tracking-[0.25em] text-primary">
                            Sugerencias
                          </h2>
                          <p class="mt-3 text-2xl md:text-3xl font-black tracking-tight">
                            Propiedades similares
                          </p>
                        </div>
                        <a
                          href="/projects"
                          class="hidden md:inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-slate-600 dark:text-slate-400 hover:text-primary dark:hover:text-primary transition-colors"
                        >
                          Ver todas
                          <Icon name="arrow-right" size={16} />
                        </a>
                      </div>

                      <div class="mt-8 grid grid-cols-1 md:grid-cols-3 gap-6">
                        {similar.map((p) => (
                          <a
                            href={`/projects/${p.slug}`}
                            class="group rounded-2xl overflow-hidden border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 hover:border-primary/40 transition-colors"
                          >
                            <div class="relative">
                              <div class="absolute top-4 left-4 z-20">
                                <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest bg-white/90 text-slate-900">
                                  {p.operation}
                                </span>
                              </div>
                              <div class="aspect-[16/10] bg-slate-200 dark:bg-slate-800">
                                <Image
                                  src={p.images[0]}
                                  alt={p.title}
                                  class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-700"
                                  loading="lazy"
                                  decoding="async"
                                  widths={[360, 540, 720, p.images[0].width]}
                                  sizes="(max-width: 768px) 100vw, 33vw"
                                  quality={75}
                                  format="webp"
                                />
                              </div>
                            </div>
                            <div class="p-6">
                              <p class="text-xs font-bold uppercase tracking-widest text-primary">
                                {p.type}
                              </p>
                              <h3 class="mt-3 text-lg font-black tracking-tight group-hover:text-primary transition-colors">
                                {p.title}
                              </h3>
                              <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
                                {p.location}
                              </p>
                              <p class="mt-4 text-sm font-black text-slate-900 dark:text-slate-100">
                                {p.price}
                              </p>
                            </div>
                          </a>
                        ))}
                      </div>
                    </div>
                  ) : null}
                </div>
              </div>

              <aside class="lg:col-span-4 lg:sticky lg:top-28">
                <div class="rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-8">
                  <div class="flex items-start justify-between gap-4">
                    <div>
                      <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400">
                        Precio
                      </p>
                      <p class="mt-2 text-3xl font-black tracking-tight">
                        {property.price}
                      </p>
                      <p class="mt-3 text-sm text-slate-600 dark:text-slate-400">
                        {property.operation} • {property.type}
                      </p>
                    </div>
                    <div class="size-10 rounded-xl bg-primary/10 flex items-center justify-center">
                      <Icon
                        name="message-circle"
                        size={20}
                        class="text-primary"
                      />
                    </div>
                  </div>

                  <div class="mt-6 space-y-3 text-sm">
                    <div class="flex items-center justify-between gap-4">
                      <span class="text-slate-600 dark:text-slate-400">
                        Ubicación
                      </span>
                      <span class="text-slate-900 dark:text-slate-100 font-semibold text-right">
                        {property.location}
                      </span>
                    </div>
                    {typeof property.areaM2 === "number" ? (
                      <div class="flex items-center justify-between gap-4">
                        <span class="text-slate-600 dark:text-slate-400">
                          Área
                        </span>
                        <span class="text-slate-900 dark:text-slate-100 font-semibold">
                          {property.areaM2} m²
                        </span>
                      </div>
                    ) : null}
                    {typeof property.bedrooms === "number" ? (
                      <div class="flex items-center justify-between gap-4">
                        <span class="text-slate-600 dark:text-slate-400">
                          Habitaciones
                        </span>
                        <span class="text-slate-900 dark:text-slate-100 font-semibold">
                          {property.bedrooms}
                        </span>
                      </div>
                    ) : null}
                    {typeof property.bathrooms === "number" ? (
                      <div class="flex items-center justify-between gap-4">
                        <span class="text-slate-600 dark:text-slate-400">
                          Baños
                        </span>
                        <span class="text-slate-900 dark:text-slate-100 font-semibold">
                          {property.bathrooms}
                        </span>
                      </div>
                    ) : null}
                    {typeof property.parking === "number" ? (
                      <div class="flex items-center justify-between gap-4">
                        <span class="text-slate-600 dark:text-slate-400">
                          Parqueaderos
                        </span>
                        <span class="text-slate-900 dark:text-slate-100 font-semibold">
                          {property.parking}
                        </span>
                      </div>
                    ) : null}
                  </div>

                  <div class="mt-8 grid grid-cols-1 gap-3">
                    <Button
                      href={`/contact?propiedad=${property.slug}`}
                      variant="primary"
                      size="lg"
                    >
                      Escribir ahora
                    </Button>
                    <Button href="/contact" variant="outline" size="lg">
                      Recibir opciones
                    </Button>
                  </div>

                  <div class="mt-8 rounded-xl bg-slate-50 dark:bg-slate-800/50 p-5 border border-slate-200 dark:border-slate-800">
                    <div class="flex items-start gap-3">
                      <Icon
                        name="clock"
                        size={18}
                        class="text-primary mt-0.5"
                      />
                      <div>
                        <p class="text-xs font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400">
                          Respuesta rápida
                        </p>
                        <p class="mt-2 text-sm text-slate-700 dark:text-slate-200 leading-relaxed">
                          Te respondemos con disponibilidad y próximos pasos
                          para agendar visita.
                        </p>
                      </div>
                    </div>
                  </div>
                </div>
              </aside>
            </div>
          </Container>
        </section>
      ) : (
        <section class="py-20">
          <Container size="xl">
            <div class="rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-10 text-center">
              <p class="text-xs font-bold uppercase tracking-widest text-primary">
                No encontrada
              </p>
              <h1 class="mt-4 text-3xl md:text-4xl font-black tracking-tight">
                Esta propiedad no existe
              </h1>
              <p class="mt-4 text-slate-600 dark:text-slate-400 max-w-xl mx-auto">
                Puede que el enlace haya cambiado o que la propiedad ya no esté
                publicada.
              </p>
              <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
                <Button href="/projects" variant="primary" size="md">
                  Ver propiedades
                </Button>
                <Button href="/contact" variant="outline" size="md">
                  Contacto
                </Button>
              </div>
            </div>
          </Container>
        </section>
      )
    }
  </main>
  <Footer />
</Layout>

<script is:inline>
  (function () {
    var lightbox = document.querySelector("[data-lightbox]");
    var backdrop = document.querySelector("[data-lightbox-backdrop]");
    var closeBtn = document.querySelector("[data-lightbox-close]");
    var prevBtn = document.querySelector("[data-lightbox-prev]");
    var nextBtn = document.querySelector("[data-lightbox-next]");
    var imgEl = document.querySelector("[data-lightbox-img]");
    var countEl = document.querySelector("[data-lightbox-count]");
    var thumbsEl = document.querySelector("[data-lightbox-thumbs]");
    var loaderEl = document.querySelector("[data-lightbox-loader]");
    var galleryItems = Array.from(document.querySelectorAll("[data-gallery-item]"));
    var openAllBtn = document.querySelector("[data-gallery-open]");

    if (!lightbox || !imgEl || !countEl || !galleryItems.length) return;

    var sources = galleryItems
      .map(function (item) {
        return {
          src: item.getAttribute("data-lightbox-src") || "",
          alt: item.getAttribute("data-lightbox-alt") || "",
        };
      })
      .filter(function (s) { return s.src !== ""; });

    var currentIndex = 0;

    // Construir tira de miniaturas
    if (thumbsEl && sources.length) {
      sources.forEach(function (src, i) {
        var btn = document.createElement("button");
        btn.type = "button";
        btn.setAttribute("data-thumb-index", String(i));
        btn.style.cssText =
          "flex-shrink:0;width:56px;height:56px;border-radius:6px;overflow:hidden;border:2px solid transparent;opacity:0.4;transition:all 0.2s ease;";
        var img = document.createElement("img");
        img.src = src.src;
        img.alt = src.alt;
        img.style.cssText = "width:100%;height:100%;object-fit:cover;";
        img.loading = "lazy";
        btn.appendChild(img);
        btn.addEventListener("click", function () { openAt(i); });
        thumbsEl.appendChild(btn);
      });
    }

    function updateThumbs() {
      if (!thumbsEl) return;
      var thumbs = thumbsEl.querySelectorAll("[data-thumb-index]");
      thumbs.forEach(function (t, i) {
        if (i === currentIndex) {
          t.style.borderColor = "white";
          t.style.opacity = "1";
        } else {
          t.style.borderColor = "transparent";
          t.style.opacity = "0.4";
        }
      });
      var active = thumbsEl.querySelector('[data-thumb-index="' + currentIndex + '"]');
      if (active) active.scrollIntoView({ behavior: "smooth", block: "nearest", inline: "center" });
    }

    function setOpen(isOpen) {
      if (isOpen) {
        lightbox.style.display = "block";
        requestAnimationFrame(function () {
          requestAnimationFrame(function () {
            lightbox.style.opacity = "1";
          });
        });
        lightbox.setAttribute("aria-hidden", "false");
        document.documentElement.classList.add("overflow-hidden");
        document.body.classList.add("overflow-hidden");
      } else {
        lightbox.style.opacity = "0";
        lightbox.setAttribute("aria-hidden", "true");
        document.documentElement.classList.remove("overflow-hidden");
        document.body.classList.remove("overflow-hidden");
        setTimeout(function () {
          lightbox.style.display = "none";
          imgEl.removeAttribute("src");
          imgEl.alt = "";
        }, 260);
      }
    }

    function render(fade) {
      if (fade === undefined) fade = true;
      var item = sources[currentIndex];
      if (!item || !item.src) return;
      countEl.textContent = (currentIndex + 1) + " / " + sources.length;
      if (fade) {
        imgEl.style.opacity = "0";
        if (loaderEl) loaderEl.style.opacity = "1";
      }
      var newImg = new Image();
      newImg.onload = function () {
        imgEl.src = item.src;
        imgEl.alt = item.alt;
        imgEl.style.opacity = "1";
        if (loaderEl) loaderEl.style.opacity = "0";
        updateThumbs();
      };
      newImg.onerror = function () {
        imgEl.src = item.src;
        imgEl.alt = item.alt;
        imgEl.style.opacity = "1";
        if (loaderEl) loaderEl.style.opacity = "0";
        updateThumbs();
      };
      newImg.src = item.src;
    }

    function openAt(index) {
      currentIndex = Math.max(0, Math.min(index, sources.length - 1));
      render(false);
      setOpen(true);
    }

    function close() { setOpen(false); }
    function prev() {
      currentIndex = (currentIndex - 1 + sources.length) % sources.length;
      render();
    }
    function next() {
      currentIndex = (currentIndex + 1) % sources.length;
      render();
    }

    galleryItems.forEach(function (item) {
      item.addEventListener("click", function () {
        var index = Number(item.getAttribute("data-gallery-index") || "0");
        openAt(index);
      });
    });

    if (openAllBtn) openAllBtn.addEventListener("click", function () { openAt(0); });
    if (closeBtn) closeBtn.addEventListener("click", close);
    if (backdrop) backdrop.addEventListener("click", close);
    if (prevBtn) prevBtn.addEventListener("click", prev);
    if (nextBtn) nextBtn.addEventListener("click", next);

    document.addEventListener("keydown", function (e) {
      if (lightbox.getAttribute("aria-hidden") === "true") return;
      if (e.key === "Escape") close();
      if (e.key === "ArrowLeft") prev();
      if (e.key === "ArrowRight") next();
    });

    // Soporte táctil / swipe
    var touchStartX = 0;
    lightbox.addEventListener("touchstart", function (e) {
      touchStartX = e.changedTouches[0].screenX;
    }, { passive: true });
    lightbox.addEventListener("touchend", function (e) {
      var diff = touchStartX - e.changedTouches[0].screenX;
      if (Math.abs(diff) > 50) {
        if (diff > 0) next();
        else prev();
      }
    }, { passive: true });
  })();
</script>

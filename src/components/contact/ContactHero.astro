---
import Container from '../shared/Container.astro';
---

<Container>
  <div class="max-w-3xl pt-20 pb-12">
    <span class="text-primary text-xs font-bold tracking-[0.2em] uppercase mb-4 block">
      Contáctanos
    </span>
    <h2 class="text-5xl md:text-7xl font-black leading-tight tracking-tight mb-6">
      Agenda una asesoría.
    </h2>
    <p class="text-slate-500 dark:text-slate-400 text-lg md:text-xl leading-relaxed max-w-2xl">
      Cuéntanos qué estás buscando (venta o arriendo) y te compartimos opciones según tu zona y presupuesto.
    </p>
  </div>
</Container>

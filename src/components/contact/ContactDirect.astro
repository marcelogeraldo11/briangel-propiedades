---
import Icon from '../shared/Icon.astro';
---

<div class="space-y-4">
  <h3 class="text-xs font-bold uppercase tracking-[0.2em] text-primary">Contacto directo</h3>
  <div class="space-y-2">
    <p class="flex items-center gap-3 text-lg font-light">
      <Icon name="phone" size={20} class="text-slate-400" />
      +57 300 000 0000
    </p>
    <p class="flex items-center gap-3 text-lg font-light">
      <Icon name="mail" size={20} class="text-slate-400" />
      contacto@briangel.com
    </p>
  </div>
</div>

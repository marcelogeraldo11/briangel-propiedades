---
import Container from "../shared/Container.astro";
import Logo from "../shared/Logo.astro";
import Icon from "../shared/Icon.astro";
---

<footer
  class="border-t border-slate-200 dark:border-slate-800 bg-background-light dark:bg-background-dark py-12"
>
  <Container size="xl">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12">
      <div class="col-span-1 md:col-span-2">
        <div
          class="flex items-center gap-3 text-slate-900 dark:text-slate-100 mb-6"
        >
          <Logo size="sm" />
          <span class="font-bold uppercase tracking-tight">Briangel</span>
        </div>
        <p
          class="text-slate-600 dark:text-slate-300 text-sm max-w-sm font-light leading-relaxed"
        >
          Propiedades en venta y arriendo. Te acompañamos en todo el proceso:
          búsqueda, visitas, negociación y cierre.
        </p>
      </div>

      <div>
        <h2
          class="text-slate-900 dark:text-slate-100 text-xs font-bold uppercase tracking-widest mb-6"
        >
          Redes
        </h2>
        <ul class="space-y-3">
          <li>
            <a
              href="#"
              class="text-slate-600 dark:text-slate-300 hover:text-primary transition-colors text-sm font-light flex items-center gap-2"
            >
              <Icon name="brand-instagram" size={16} />
              Instagram
            </a>
          </li>
          <li>
            <a
              href="#"
              class="text-slate-600 dark:text-slate-300 hover:text-primary transition-colors text-sm font-light flex items-center gap-2"
            >
              <Icon name="brand-linkedin" size={16} />
              LinkedIn
            </a>
          </li>
          <li>
            <a
              href="#"
              class="text-slate-600 dark:text-slate-300 hover:text-primary transition-colors text-sm font-light flex items-center gap-2"
            >
              <Icon name="brand-behance" size={16} />
              Behance
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h2
          class="text-slate-900 dark:text-slate-100 text-xs font-bold uppercase tracking-widest mb-6"
        >
          Contacto
        </h2>
        <p class="text-slate-600 dark:text-slate-300 text-sm font-light mb-1">
          General:
        </p>
        <p
          class="text-slate-900 dark:text-slate-100 text-sm font-medium mb-4 flex items-center gap-2"
        >
          <Icon name="mail" size={16} class="text-primary" />
          contacto@briangel.com
        </p>
        <p class="text-slate-600 dark:text-slate-300 text-sm font-light mb-1">
          Ventas y arriendos:
        </p>
        <p
          class="text-slate-900 dark:text-slate-100 text-sm font-medium flex items-center gap-2"
        >
          <Icon name="mail" size={16} class="text-primary" />
          comercial@briangel.com
        </p>
      </div>
    </div>

    <div
      class="mt-16 pt-8 border-t border-slate-200 dark:border-slate-800 flex flex-col md:flex-row justify-between items-center gap-4"
    >
      <p
        class="text-slate-600 dark:text-slate-500 text-[10px] uppercase tracking-widest font-medium"
      >
        © 2024 Briangel. Todos los derechos reservados.
      </p>
      <div class="flex gap-8">
        <a
          href="/privacy"
          class="text-slate-600 dark:text-slate-500 text-[10px] uppercase tracking-widest font-medium hover:text-slate-900 dark:hover:text-slate-100 transition-colors"
        >
          Privacidad
        </a>
        <a
          href="/terms"
          class="text-slate-600 dark:text-slate-500 text-[10px] uppercase tracking-widest font-medium hover:text-slate-900 dark:hover:text-slate-100 transition-colors"
        >
          Términos
        </a>
      </div>
    </div>
  </Container>
</footer>

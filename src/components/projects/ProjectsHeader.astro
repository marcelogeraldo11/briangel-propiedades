---
import Container from '../shared/Container.astro';
---

<Container>
  <div class="mb-12">
    <h2 class="text-slate-900 dark:text-slate-100 text-4xl md:text-5xl font-black leading-tight tracking-tight mb-4">
      Propiedades
    </h2>
    <p class="text-slate-500 dark:text-slate-400 text-lg max-w-2xl font-light">
      Explora opciones en venta y arriendo. Filtra por tipo y elige la propiedad que mejor se ajuste a tu estilo de vida.
    </p>
  </div>
</Container>

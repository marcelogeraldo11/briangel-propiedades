---
import Container from '../shared/Container.astro';
import Timeline from './Timeline.astro';
import { Image } from 'astro:assets';
import philosophyImage from '../../assets/img/about-page-img-06.jpg';

const timelineEvents = [
  {
    year: "2016",
    title: "Inicio",
    description: "Nacemos con el objetivo de hacer más simple la compra y arriendo de vivienda.",
    isFirst: true
  },
  {
    year: "2020",
    title: "Expansión",
    description: "Ampliamos cobertura por zonas clave y fortalecemos el acompañamiento comercial."
  },
  {
    year: "2024",
    title: "Crecimiento",
    description: "Optimizamos procesos para publicar, filtrar y agendar visitas con mayor rapidez."
  }
];
---

<section class="py-24">
  <Container>
    <div class="grid lg:grid-cols-2 gap-20 lg:gap-32 items-start">
      {/* Philosophy Column */}
      <div class="space-y-8">
        <div class="flex items-center gap-4">
          <div class="h-[1px] w-12 bg-primary" />
          <h2 class="text-sm font-bold uppercase tracking-[0.3em] text-primary">Filosofía</h2>
        </div>
        <h3 class="text-3xl font-black leading-tight">Transparencia, rapidez y decisiones informadas.</h3>
        <p class="text-slate-600 dark:text-slate-400 leading-loose">
          En Briangel creemos en la información clara: precio, ubicación y características reales. Nuestro enfoque se centra en filtrar opciones con criterio para ahorrar tiempo y evitar sorpresas.
        </p>
        <p class="text-slate-600 dark:text-slate-400 leading-loose">
          Acompañamos cada paso: publicación, visitas, negociación y documentación, para que el cierre sea sencillo y seguro.
        </p>
        <div class="pt-4">
         <Image
        src={philosophyImage}
            alt="Detalle de una propiedad con acabados modernos"
       widths={[240, 540, 720, philosophyImage.width]}
  sizes={`(max-width: 360px) 240px, (max-width: 720px) 540px, (max-width: 1600px) 720px, ${philosophyImage.width}px`}
  
      />
        </div>
      </div>

      {/* History Column */}
      <div class="space-y-8 lg:pt-32">
        <div class="flex items-center gap-4">
          <div class="h-[1px] w-12 bg-primary" />
          <h2 class="text-sm font-bold uppercase tracking-[0.3em] text-primary">Nuestro camino</h2>
        </div>
        <h3 class="text-3xl font-black leading-tight">Creciendo con nuestros clientes.</h3>
        <div class="space-y-10">
          {timelineEvents.map((event) => (
            <Timeline
              year={event.year}
              title={event.title}
              description={event.description}
              isFirst={event.isFirst}
            />
          ))}
        </div>
      </div>
    </div>
  </Container>
</section>

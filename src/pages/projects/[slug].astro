---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/home/Navbar.astro";
import Footer from "../../components/shared/Footer.astro";
import Container from "../../components/shared/Container.astro";
import Icon from "../../components/shared/Icon.astro";
import Button from "../../components/shared/Button.astro";
import { Image } from "astro:assets";
import { properties } from "../../data/properties";

export function getStaticPaths() {
  return properties.map((property) => ({
    params: { slug: property.slug },
  }));
}

const { slug } = Astro.params;
const property = properties.find((p) => p.slug === slug);
const similar = properties.filter((p) => p.slug !== slug).slice(0, 3);

const title = property
  ? `${property.title} | ${property.operation}`
  : "Propiedad no encontrada";
const description = property
  ? `${property.type} en ${property.location}. ${property.operation} • ${property.price}.`
  : "No encontramos la propiedad solicitada.";
---

<Layout title={title} description={description}>
  <Navbar />
  <main class="flex-1">
    <section class="pt-24">
      <Container size="xl">
        <div class="flex items-center justify-between gap-6">
          <nav
            class="flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400"
          >
            <a href="/" class="hover:text-primary transition-colors">Inicio</a>
            <span class="opacity-60">/</span>
            <a href="/projects" class="hover:text-primary transition-colors"
              >Propiedades</a
            >
            <span class="opacity-60">/</span>
            <span class="text-slate-900 dark:text-slate-100">
              {property ? property.type : "Detalle"}
            </span>
          </nav>

          <a
            href="/projects"
            class="hidden sm:inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-primary"
          >
            <Icon name="arrow-right" size={16} class="rotate-180" />
            Volver
          </a>
        </div>
      </Container>
    </section>

    {
      property ? (
        <section class="pt-10 pb-16">
          <Container size="xl">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-14 items-start">
              <div class="lg:col-span-8">
                <div class="relative overflow-hidden rounded-2xl bg-slate-200 dark:bg-slate-900 border border-slate-200 dark:border-slate-800">
                  <div class="absolute inset-0 bg-[radial-gradient(800px_300px_at_0%_0%,color-mix(in_srgb,var(--color-primary)_22%,transparent),transparent_70%)]" />
                  <div class="absolute inset-0 bg-[radial-gradient(900px_420px_at_100%_10%,rgba(255,255,255,0.20),transparent_60%)] dark:bg-[radial-gradient(900px_420px_at_100%_10%,rgba(255,255,255,0.08),transparent_60%)]" />

                  <div class="relative">
                    <div class="absolute top-5 left-5 z-20 flex flex-wrap items-center gap-2">
                      <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest bg-white/90 text-slate-900">
                        {property.operation}
                      </span>
                      <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest bg-white/90 text-slate-900">
                        {property.type}
                      </span>
                    </div>

                    <div class="absolute top-5 right-5 z-20">
                      <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest bg-white/90 text-slate-900">
                        {property.price}
                      </span>
                    </div>

                    <div class="aspect-[16/10]">
                      <Image
                        src={property.images[0]}
                        alt={property.title}
                        class="w-full h-full object-cover"
                        loading="eager"
                        fetchpriority="high"
                        widths={[640, 960, 1280, property.images[0].width]}
                        sizes="(max-width: 1024px) 100vw, 66vw"
                        quality={80}
                        format="webp"
                      />
                    </div>
                  </div>
                </div>

                <div class="mt-10">
                  <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
                    <div class="max-w-2xl">
                      <h1 class="text-4xl md:text-6xl font-black tracking-tight leading-[0.95]">
                        {property.title}
                      </h1>
                      <p class="mt-4 text-slate-600 dark:text-slate-300 text-base md:text-lg font-light leading-relaxed">
                        {property.description}
                      </p>
                      <div class="mt-6 flex flex-wrap items-center gap-3 text-sm">
                        <span class="inline-flex items-center gap-2 px-3 py-2 rounded-lg bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800">
                          <Icon name="map-pin" size={18} class="text-primary" />
                          <span class="text-slate-700 dark:text-slate-300">
                            {property.location}
                          </span>
                        </span>
                        {typeof property.stratum === "number" ? (
                          <span class="inline-flex items-center gap-2 px-3 py-2 rounded-lg bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800">
                            <Icon
                              name="shield"
                              size={18}
                              class="text-primary"
                            />
                            <span class="text-slate-700 dark:text-slate-300">
                              Estrato {property.stratum}
                            </span>
                          </span>
                        ) : null}
                      </div>
                    </div>

                    <div class="flex items-center gap-3">
                      <Button href="/contact" variant="primary" size="md">
                        Quiero más info
                      </Button>
                      <Button href="/projects" variant="outline" size="md">
                        Seguir buscando
                      </Button>
                    </div>
                  </div>

                  <div class="mt-10 grid grid-cols-2 md:grid-cols-4 gap-4">
                    {typeof property.bedrooms === "number" ? (
                      <div class="rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-5">
                        <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400">
                          Habitaciones
                        </p>
                        <p class="mt-2 text-2xl font-black tracking-tight">
                          {property.bedrooms}
                        </p>
                      </div>
                    ) : null}
                    {typeof property.bathrooms === "number" ? (
                      <div class="rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-5">
                        <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400">
                          Baños
                        </p>
                        <p class="mt-2 text-2xl font-black tracking-tight">
                          {property.bathrooms}
                        </p>
                      </div>
                    ) : null}
                    {typeof property.areaM2 === "number" ? (
                      <div class="rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-5">
                        <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400">
                          Área
                        </p>
                        <p class="mt-2 text-2xl font-black tracking-tight">
                          {property.areaM2} m²
                        </p>
                      </div>
                    ) : null}
                    {typeof property.parking === "number" ? (
                      <div class="rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-5">
                        <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400">
                          Parqueaderos
                        </p>
                        <p class="mt-2 text-2xl font-black tracking-tight">
                          {property.parking}
                        </p>
                      </div>
                    ) : null}
                  </div>

                  <div class="mt-12 grid grid-cols-1 md:grid-cols-12 gap-8">
                    <div class="md:col-span-7">
                      <h2 class="text-sm font-bold uppercase tracking-[0.25em] text-primary">
                        Detalles
                      </h2>
                      <div class="mt-5 rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-7">
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                          {property.features.map((feature) => (
                            <div class="flex items-start gap-3">
                              <Icon
                                name="check"
                                size={18}
                                class="text-primary mt-0.5"
                              />
                              <span class="text-slate-700 dark:text-slate-300 text-sm leading-relaxed">
                                {feature}
                              </span>
                            </div>
                          ))}
                        </div>
                      </div>
                    </div>

                    <div class="md:col-span-5">
                      <h2 class="text-sm font-bold uppercase tracking-[0.25em] text-primary">
                        Galería
                      </h2>
                      <div class="mt-5 grid grid-cols-3 gap-3">
                        {property.images.slice(0, 3).map((img, index) => (
                          <div
                            class:list={[
                              "overflow-hidden rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-200 dark:bg-slate-800",
                              index === 0 ? "col-span-3" : "col-span-1",
                            ]}
                          >
                            <div
                              class:list={[
                                index === 0 ? "aspect-[16/9]" : "aspect-[4/3]",
                              ]}
                            >
                              <Image
                                src={img}
                                alt={`${property.title} - imagen ${index + 1}`}
                                class="w-full h-full object-cover hover:scale-[1.02] transition-transform duration-700"
                                loading="lazy"
                                decoding="async"
                                widths={[360, 540, 720, img.width]}
                                sizes="(max-width: 768px) 100vw, 33vw"
                                quality={75}
                                format="webp"
                              />
                            </div>
                          </div>
                        ))}
                      </div>

                      <div class="mt-8 rounded-2xl border border-primary/20 bg-primary/5 dark:bg-primary/10 p-7">
                        <p class="text-xs font-bold uppercase tracking-widest text-primary">
                          ¿Te interesa esta propiedad?
                        </p>
                        <p class="mt-3 text-sm text-slate-700 dark:text-slate-200 leading-relaxed">
                          Te ayudamos a agendar visita y resolver dudas de
                          documentación y negociación.
                        </p>
                        <div class="mt-6">
                          <Button
                            href={`/contact?propiedad=${property.slug}`}
                            variant="primary"
                            size="md"
                          >
                            Agendar visita
                          </Button>
                        </div>
                      </div>
                    </div>
                  </div>

                  {similar.length ? (
                    <div class="mt-16">
                      <div class="flex items-end justify-between gap-6">
                        <div>
                          <h2 class="text-sm font-bold uppercase tracking-[0.25em] text-primary">
                            Sugerencias
                          </h2>
                          <p class="mt-3 text-2xl md:text-3xl font-black tracking-tight">
                            Propiedades similares
                          </p>
                        </div>
                        <a
                          href="/projects"
                          class="hidden md:inline-flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-slate-600 dark:text-slate-400 hover:text-primary dark:hover:text-primary transition-colors"
                        >
                          Ver todas
                          <Icon name="arrow-right" size={16} />
                        </a>
                      </div>

                      <div class="mt-8 grid grid-cols-1 md:grid-cols-3 gap-6">
                        {similar.map((p) => (
                          <a
                            href={`/projects/${p.slug}`}
                            class="group rounded-2xl overflow-hidden border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 hover:border-primary/40 transition-colors"
                          >
                            <div class="relative">
                              <div class="absolute top-4 left-4 z-20">
                                <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest bg-white/90 text-slate-900">
                                  {p.operation}
                                </span>
                              </div>
                              <div class="aspect-[16/10] bg-slate-200 dark:bg-slate-800">
                                <Image
                                  src={p.images[0]}
                                  alt={p.title}
                                  class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-700"
                                  loading="lazy"
                                  decoding="async"
                                  widths={[360, 540, 720, p.images[0].width]}
                                  sizes="(max-width: 768px) 100vw, 33vw"
                                  quality={75}
                                  format="webp"
                                />
                              </div>
                            </div>
                            <div class="p-6">
                              <p class="text-xs font-bold uppercase tracking-widest text-primary">
                                {p.type}
                              </p>
                              <h3 class="mt-3 text-lg font-black tracking-tight group-hover:text-primary transition-colors">
                                {p.title}
                              </h3>
                              <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
                                {p.location}
                              </p>
                              <p class="mt-4 text-sm font-black text-slate-900 dark:text-slate-100">
                                {p.price}
                              </p>
                            </div>
                          </a>
                        ))}
                      </div>
                    </div>
                  ) : null}
                </div>
              </div>

              <aside class="lg:col-span-4 lg:sticky lg:top-28">
                <div class="rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-8">
                  <div class="flex items-start justify-between gap-4">
                    <div>
                      <p class="text-[10px] font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400">
                        Precio
                      </p>
                      <p class="mt-2 text-3xl font-black tracking-tight">
                        {property.price}
                      </p>
                      <p class="mt-3 text-sm text-slate-600 dark:text-slate-400">
                        {property.operation} • {property.type}
                      </p>
                    </div>
                    <div class="size-10 rounded-xl bg-primary/10 flex items-center justify-center">
                      <Icon
                        name="message-circle"
                        size={20}
                        class="text-primary"
                      />
                    </div>
                  </div>

                  <div class="mt-6 space-y-3 text-sm">
                    <div class="flex items-center justify-between gap-4">
                      <span class="text-slate-600 dark:text-slate-400">
                        Ubicación
                      </span>
                      <span class="text-slate-900 dark:text-slate-100 font-semibold text-right">
                        {property.location}
                      </span>
                    </div>
                    {typeof property.areaM2 === "number" ? (
                      <div class="flex items-center justify-between gap-4">
                        <span class="text-slate-600 dark:text-slate-400">
                          Área
                        </span>
                        <span class="text-slate-900 dark:text-slate-100 font-semibold">
                          {property.areaM2} m²
                        </span>
                      </div>
                    ) : null}
                    {typeof property.bedrooms === "number" ? (
                      <div class="flex items-center justify-between gap-4">
                        <span class="text-slate-600 dark:text-slate-400">
                          Habitaciones
                        </span>
                        <span class="text-slate-900 dark:text-slate-100 font-semibold">
                          {property.bedrooms}
                        </span>
                      </div>
                    ) : null}
                    {typeof property.bathrooms === "number" ? (
                      <div class="flex items-center justify-between gap-4">
                        <span class="text-slate-600 dark:text-slate-400">
                          Baños
                        </span>
                        <span class="text-slate-900 dark:text-slate-100 font-semibold">
                          {property.bathrooms}
                        </span>
                      </div>
                    ) : null}
                    {typeof property.parking === "number" ? (
                      <div class="flex items-center justify-between gap-4">
                        <span class="text-slate-600 dark:text-slate-400">
                          Parqueaderos
                        </span>
                        <span class="text-slate-900 dark:text-slate-100 font-semibold">
                          {property.parking}
                        </span>
                      </div>
                    ) : null}
                  </div>

                  <div class="mt-8 grid grid-cols-1 gap-3">
                    <Button
                      href={`/contact?propiedad=${property.slug}`}
                      variant="primary"
                      size="lg"
                    >
                      Escribir ahora
                    </Button>
                    <Button href="/contact" variant="outline" size="lg">
                      Recibir opciones
                    </Button>
                  </div>

                  <div class="mt-8 rounded-xl bg-slate-50 dark:bg-slate-800/50 p-5 border border-slate-200 dark:border-slate-800">
                    <div class="flex items-start gap-3">
                      <Icon
                        name="clock"
                        size={18}
                        class="text-primary mt-0.5"
                      />
                      <div>
                        <p class="text-xs font-bold uppercase tracking-widest text-slate-500 dark:text-slate-400">
                          Respuesta rápida
                        </p>
                        <p class="mt-2 text-sm text-slate-700 dark:text-slate-200 leading-relaxed">
                          Te respondemos con disponibilidad y próximos pasos
                          para agendar visita.
                        </p>
                      </div>
                    </div>
                  </div>
                </div>
              </aside>
            </div>
          </Container>
        </section>
      ) : (
        <section class="py-20">
          <Container size="xl">
            <div class="rounded-2xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 p-10 text-center">
              <p class="text-xs font-bold uppercase tracking-widest text-primary">
                No encontrada
              </p>
              <h1 class="mt-4 text-3xl md:text-4xl font-black tracking-tight">
                Esta propiedad no existe
              </h1>
              <p class="mt-4 text-slate-600 dark:text-slate-400 max-w-xl mx-auto">
                Puede que el enlace haya cambiado o que la propiedad ya no esté
                publicada.
              </p>
              <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
                <Button href="/projects" variant="primary" size="md">
                  Ver propiedades
                </Button>
                <Button href="/contact" variant="outline" size="md">
                  Contacto
                </Button>
              </div>
            </div>
          </Container>
        </section>
      )
    }
  </main>
  <Footer />
</Layout>

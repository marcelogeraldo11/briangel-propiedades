---
import logoSrc from '../../assets/img/logo-briangel.png';

export interface Props {
  class?: string;
  size?: 'sm' | 'md' | 'lg';
}

const { class: className = '', size = 'md' } = Astro.props;

const sizeMap = {
  sm: '32px',
  md: '40px',
  lg: '56px'
};
---

<img
  src={logoSrc.src}
  alt="Briangel logo"
  height={sizeMap[size]}
  class:list={[className]}
  style={`height: ${sizeMap[size]}; width: auto;`}
/>